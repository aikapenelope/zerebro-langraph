# ┌──────────────────────────────────────────────────────────┐
# │  Zerebro — Environment Variables                        │
# │                                                         │
# │  Copy this file to .env and fill in your keys:          │
# │    cp .env.example .env                                 │
# │                                                         │
# │  Then run:                                              │
# │    docker compose up        (Docker)                    │
# │    ./run.sh                 (local, Mac/Linux)          │
# └──────────────────────────────────────────────────────────┘

# === REQUIRED KEYS ===

# Anthropic API key — powers all agents (Claude Haiku 4.5)
# Get yours at: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-xxxxx

# LangSmith API key — needed for langgraph dev server + deep-agents-ui SDK
# Free tier is enough. Get yours at: https://smith.langchain.com/settings
LANGSMITH_API_KEY=lsv2_pt_xxxxx

# === OPTIONAL ===

# Set to "true" to send traces to LangSmith (costs free-tier quota)
LANGSMITH_TRACING=false

# OpenAI (inactive, uncomment when ready)
# OPENAI_API_KEY=sk-xxxxx

# === MCP Server URLs (only needed if your agents use them) ===
MCP_N8N_URL=http://localhost:5678/mcp
MCP_REMOTION_URL=http://localhost:3000/mcp
MCP_GRAFITI_URL=http://localhost:8001/mcp
MCP_MEM0_URL=http://localhost:8002/mcp

# === Phoenix Observability (optional) ===
PHOENIX_PORT=6006
